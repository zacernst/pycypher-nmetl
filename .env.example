# Copy to .env and set real values before running docker-compose.
# All credentials are REQUIRED — docker-compose will error if unset.

# ── Production stack (docker-compose.prod.yml) ─────────────────────────
QUERY_PORT=8078                         # Host port for query service
QUERY_REPLICAS=2                        # Number of query service replicas
PYCYPHER_BACKEND=auto                   # Backend engine: auto|pandas|duckdb|polars
GRAFANA_PASSWORD=<set-a-strong-password>

# ── Kubernetes deployment ──────────────────────────────────────────────
KUBE_NAMESPACE=pycypher                 # K8s namespace
DEPLOY_TIMEOUT=120s                     # Rollout timeout

# ── External services (docker-compose.yml) ─────────────────────────────
# Spark cluster
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_RPC_SECRET=<generate-a-strong-secret>

# Neo4j credentials (used by docker-compose and the neo4j Python driver)
NEO4J_USER=neo4j
NEO4J_PASSWORD=<set-a-strong-password>
NEO4J_URI=bolt://neo4j:7687

# Nominatim geocoder
NOMINATIM_PASSWORD=<set-a-strong-password>
NOMINATIM_URL=http://nominatim:8080   # inside Docker; use http://localhost:8092 from host

# Optional: browser-based VS Code password
CODE_SERVER_PASSWORD=<set-a-strong-password>
