        "done"


rule download_ahs_data:
    resources:
        census_download=1
    output: temp(f"{DATA_DIR}/ahs_2023_csv.zip")
    shell:
        "sleep $((5 + RANDOM % 10)) && "
        "for i in {{1..3}}; do "
        f"  {CENSUS_WGET} --timeout={SHORT_TIMEOUT_SECONDS} --tries=1"
        "    'https://www2.census.gov/programs-surveys/ahs/2023/AHS%202023%20National%20PUF%20v1.1%20Flat%20CSV.zip'"
        "    -O {output} && break || "
        "  (echo 'AHS data download attempt $i failed, waiting before retry...' && sleep $((30 * i))); "
        "done"


rule extract_ahs:
    input:
        labels = f"{DATA_DIR}/ahs_2023_labels.zip",
        data   = f"{DATA_DIR}/ahs_2023_csv.zip",
    output: touch(f"{DATA_DIR}/.ahs_2023_extracted")
    shell:
        "mkdir -p \"{DATA_DIR}/ahs_2023\" &&"
        " unzip -o {input.labels} -d \"{DATA_DIR}/ahs_2023/\" &&"
        " unzip -o {input.data}   -d \"{DATA_DIR}/ahs_2023/\""


