# ===========================================================================

rule download_ahs_labels:
    resources:
        census_download=1
    output: temp(f"{DATA_DIR}/ahs_2023_labels.zip")
    shell:
        "sleep $((5 + RANDOM % 10)) && "
        "for i in {{1..3}}; do "
        f"  {CENSUS_WGET} --timeout={SHORT_TIMEOUT_SECONDS} --tries=1"
        "    'https://www2.census.gov/programs-surveys/ahs/2023/AHS%202023%20Value%20Labels%20Package.zip'"
        "    -O {output} && break || "
