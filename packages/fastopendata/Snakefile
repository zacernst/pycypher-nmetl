rule unzip_combine_american_community_survey_household_5yr_2024:
    """Unzip and concatenate 5-year ACS PUMS housing file parts.

    Extracts to 5yr_hus_tmp/ to avoid collision with 1-year psam_hus*.csv
    files. Concatenates all psam_hus*.csv parts found after extraction.
    """
    input: f"{DATA_DIR}/csv_hus_5yr.zip"
    output: f"{DATA_DIR}/psam_hus_5yr.csv"
    run:
        import subprocess, os, glob
        tmp = f"{DATA_DIR}/5yr_hus_tmp"
        os.makedirs(tmp, exist_ok=True)
        subprocess.run(["unzip", "-o", input[0], "-d", tmp], check=True)
        parts = sorted(glob.glob(f"{tmp}/psam_hus*.csv"))
        with open(output[0], "wb") as out:
            for i, part in enumerate(parts):
                with open(part, "rb") as f:
                    if i == 0:
                        out.write(f.read())
                    else:
                        f.readline()  # skip repeated header
                        out.write(f.read())

rule unzip_combine_american_community_survey_person_5yr_2024:
    """Unzip and concatenate 5-year ACS PUMS person file parts.

    The 5-year person file is split into multiple parts (typically 2–4)
    due to the larger sample size (~15M rows). Extracts to 5yr_pus_tmp/
    to avoid collision with 1-year psam_pus*.csv files. Concatenates all
    psam_pus*.csv parts found after extraction regardless of part count.
    """
    input: f"{DATA_DIR}/csv_pus_5yr.zip"
    output: f"{DATA_DIR}/psam_pus_5yr.csv"
    run:
        import subprocess, os, glob
        tmp = f"{DATA_DIR}/5yr_pus_tmp"
        os.makedirs(tmp, exist_ok=True)
        subprocess.run(["unzip", "-o", input[0], "-d", tmp], check=True)
        parts = sorted(glob.glob(f"{tmp}/psam_pus*.csv"))
        with open(output[0], "wb") as out:
            for i, part in enumerate(parts):
                with open(part, "rb") as f:
                    if i == 0:
                        out.write(f.read())
                    else:
                        f.readline()  # skip repeated header
                        out.write(f.read())

