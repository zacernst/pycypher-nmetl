rule unzip_common_core_fiscal_data_2022:
    input: f"{DATA_DIR}/common_core_fiscal_2022.zip"
    output: f"{DATA_DIR}/slfs23_1a.txt"
    shell:
        f"unzip {{input}} -d \"{DATA_DIR}/\""

rule convert_school_fiscal_to_parquet:
    input: f"{DATA_DIR}/slfs23_1a.txt"
    output: f"{DATA_DIR}/slfs23_1a.parquet"
    shell:
        f"uv run duckdb -c \""
        f"COPY ("
        f"  SELECT"
        f"    NCESSCH, FIPST, CNTY, LEAID, LEA_NAME, SCH_NAME, SCH_TYPE, LEVEL, CHARTER_TEXT,"
        f"    TRY_CAST(NULLIF(MEMBER, '-1') AS DOUBLE) AS MEMBER,"
        f"    TRY_CAST(NULLIF(Z33S,  '-1') AS DOUBLE) AS Z33S,"
        f"    TRY_CAST(NULLIF(V10S,  '-1') AS DOUBLE) AS V10S,"
        f"    TRY_CAST(NULLIF(E13S,  '-1') AS DOUBLE) AS E13S,"
        f"    TRY_CAST(NULLIF(V11S,  '-1') AS DOUBLE) AS V11S,"
        f"    TRY_CAST(NULLIF(E17S,  '-1') AS DOUBLE) AS E17S,"
        f"    TRY_CAST(NULLIF(V13S,  '-1') AS DOUBLE) AS V13S,"
        f"    TRY_CAST(NULLIF(CE4S,  '-1') AS DOUBLE) AS CE4S,"
        f"    TRY_CAST(NULLIF(CE5S,  '-1') AS DOUBLE) AS CE5S"
        f"  FROM read_csv('{DATA_DIR}/slfs23_1a.txt', delim=chr(9), header=true, nullstr=['-1', '-2'])"
        f") TO '{DATA_DIR}/slfs23_1a.parquet' (FORMAT PARQUET, COMPRESSION 'ZSTD');\""

rule download_common_core_fiscal_data_2022:
    output: f"{DATA_DIR}/common_core_fiscal_2022.zip"
    shell:
        "wget https://nces.ed.gov/ccd/data/zip/slfs23_1a_txt.zip -O - > {output}"

rule unzip_combine_american_community_survey_household_one_year_2024:
    # resources:
    #     census_download=1
    input: f"{DATA_DIR}/csv_hus.zip"
    output: f"{DATA_DIR}/psam_hus.csv"
    shell:
        f"unzip -o {DATA_DIR}/csv_hus.zip -d \"{DATA_DIR}/\" && "
        f"cat {DATA_DIR}/psam_husa.csv > {DATA_DIR}/psam_hus.csv && "
        f"tail -n +2 {DATA_DIR}/psam_husb.csv >> {DATA_DIR}/psam_hus.csv"

rule convert_psam_pus_to_parquet:
    """Spatial join"""
    input: f"{DATA_DIR}/psam_pus.csv"
    output: f"{DATA_DIR}/psam_pus_tmp.parquet"
    shell:
        f"uv run duckdb -c \"SET preserve_insertion_order = false; SET threads = 1; SET memory_limit = '6GB'; SET temp_directory = '/tmp'; COPY '{DATA_DIR}/psam_pus.csv' TO '{DATA_DIR}/psam_pus_tmp.parquet' (FORMAT PARQUET, ROW_GROUP_SIZE 1024, COMPRESSION 'ZSTD');\""

rule add_puma_fips_to_psam_pus:
    """concatenate for fips number"""
    # f"uv run python {SCRIPTS}/add_puma_fips_to_psam_pus.py {DATA_DIR}"
    input: f"{DATA_DIR}/psam_pus_tmp.parquet"
    output: f"{DATA_DIR}/psam_pus.parquet"
    shell:
        f"uv run duckdb -c \"SET preserve_insertion_order = false; SET threads = 1; SET memory_limit = '6GB'; SET temp_directory = '/tmp'; COPY (SELECT *, STATE || PUMA AS PUMA_FIPS FROM '{DATA_DIR}/psam_pus_tmp.parquet') TO '{DATA_DIR}/psam_pus.parquet' (FORMAT PARQUET, COMPRESSION 'ZSTD');\""


rule generate_occupation_groups:
    """Write the 5-row ACS major occupation group reference CSV.

    Codes are the 4-digit ACS PUMS occupation code range boundaries (from
    ACSPUMS2024CodeLists.xls). The occ_group_code values match the occ_group
    derived column added to psam_pus.parquet in the ETL query.
    """
    output: f"{DATA_DIR}/occupation_groups.csv"
    run:
        import csv
        rows = [
            ("occ_group_code", "occ_group_name", "socp_min", "socp_max"),
            ("mgmt_business_science_arts", "Management, Business, Science, and Arts", 10, 3550),
            ("service", "Service", 3601, 4655),
            ("sales_office", "Sales and Office", 4700, 5940),
            ("natural_resources_construction", "Natural Resources, Construction, and Maintenance", 6005, 7640),
            ("production_transportation", "Production, Transportation, and Material Moving", 7700, 9760),
        ]
        with open(output[0], "w", newline="") as f:
            csv.writer(f).writerows(rows)


