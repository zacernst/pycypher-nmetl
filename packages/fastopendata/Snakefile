# #     #     "    sed 's/href=\"//' | sed 's/\"//' > \"{DATA_DIR}/puma_temp/puma_files.txt\" && "
# #     #     "  echo 'Found $(cat \"{DATA_DIR}/puma_temp/puma_files.txt\" | wc -l) PUMA files to download' && "
# #     #     "  success=true && "
# #     #     "  while IFS= read -r filename || [[ -n \"$filename\" ]]; do "
# #     #     "    echo \"Downloading $filename...\" && "
# #     #     "    sleep $((5 + RANDOM % 10)) && "
# #     #     f"    {CENSUS_WGET} -e --robots=off --timeout={SHORT_TIMEOUT_SECONDS} --tries=1"
# #     #     "      \"https://www2.census.gov/geo/tiger/TIGER2024/PUMA20/$filename\""
# #     #     "      -O \"{DATA_DIR}/$filename\" && "
# #     #     "    unzip -t \"{DATA_DIR}/$filename\" >/dev/null 2>&1 && "
# #     #     "    echo \"Successfully downloaded and validated $filename\" || "
# #     #     "    (echo \"Failed to download or validate $filename\" && success=false && break); "
# #     #     "  done < \"{DATA_DIR}/puma_temp/puma_files.txt\" && "
# #     #     "  rm -rf \"{DATA_DIR}/puma_temp\" && "
# #     #     "  if [ \"$success\" = true ]; then "
# #     #     "    (echo 'All PUMA files downloaded successfully'; touch {output}; break); "
# #     #     "  else "
# #     #     "    (echo 'PUMA download attempt $i failed' && rm -f \"{DATA_DIR}\"/tl_*puma20.zip); "
# #     #     "  fi || "
# #     #     "  (echo 'PUMA download attempt $i failed, waiting before retry...' && sleep $((60 * i))); "
# #     #     "done || "
# #     #     "(echo 'All PUMA download attempts failed'; exit 1)"
