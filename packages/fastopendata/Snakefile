rule split_contracts_by_state:
    """Extract rows for a single state from the combined FY2025 contracts CSV.

    Output used by build_state_pipeline() in fastopendata.etl.state_pipeline.
    Run per-state:
        DATA_DIR=... snakemake --cores 4 "$DATA_DIR/contracts_state_13.csv"
    """
    input: f"{DATA_DIR}/FY2025_All_Contracts_Full_20260506.csv"
    output: f"{DATA_DIR}/contracts_state_{{fips}}.csv"
    shell:
        f"STATE_FIPS={{wildcards.fips}} DATA_DIR={DATA_DIR} "
        f"uv run python {SCRIPTS}/extract_state_contracts.py"


