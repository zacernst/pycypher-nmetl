# #         # "    -O {params.filename} && "
# #     # shell:
# #     #     "sleep $((10 + RANDOM % 15)) && "
# #     #     "for i in {{1..3}}; do "
# #     #     "  echo 'Starting PUMA download attempt $i...' && "
# #     #     "  mkdir -p \"{DATA_DIR}/puma_temp\" && "
# #     #     f"  {CENSUS_WGET} -e --robots=off --recursive --wait=2 --timeout={LONG_TIMEOUT_SECONDS} --tries=1"
# #     #     "    'https://www2.census.gov/geo/tiger/TIGER2024/PUMA20/'"
# #     #     "    -O \"{DATA_DIR}/puma_temp/puma_index.html\" && "
