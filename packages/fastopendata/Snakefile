# ===================oto==========================================================
# Snakefile — fastopendata data pipeline
#
# Downloads and processes all 17 source datasets used by fastopendata.
#
# Run from packages/fastopendata/:
#   snakemake --cores 4
#
# Override data directory:
#   snakemake --cores 4 --config data_dir=/mnt/data/fastopendata
#   # OR set environment variable: DATA_DIR=/mnt/data/fastopendata snakemake --cores 4
#
# Download only a subset of targets by naming them explicitly:
#   snakemake --cores 4 raw_data/psam_pus.csv raw_data/pu2023.csv
#
# Requirements: wget, unzip, dos2unix, bunzip2, bzip2, uv
# =============================================================================

from pathlib import Path
import sys

# Add package to path for config import
sys.path.insert(0, str(Path(__file__).parent / "src"))

from fastopendata.config import config as fod_config

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

# Use centralized configuration with Snakemake config override
if "data_dir" in config:
    DATA_DIR = config["data_dir"]
else:
    DATA_DIR = fod_config.data_dir

SCRIPTS = fod_config.scripts_path

# wget flags from centralized config
CENSUS_WGET = fod_config.get_census_wget_flags()

ZIPS = fod_config.zips

SHORT_TIMEOUT_SECONDS = fod_config.short_timeout_seconds
LONG_TIMEOUT_SECONDS = fod_config.long_timeout_seconds

BACKOFF = 120

PUMA_STATE_FIPS = fod_config.puma_state_fips

# Georgia FIPS code for development subset
GEORGIA_FIPS = "13"

# ---------------------------------------------------------------------------
# all — every terminal artifact in the pipeline
# ---------------------------------------------------------------------------



rule all:
    input:
        f"{DATA_DIR}/puma_combined.shp",
        f"{DATA_DIR}/wikidata_us_points.json",
        f"{DATA_DIR}/output/cjars_joe_2022_co.csv",
        f"{DATA_DIR}/united_states_nodes.csv",
        f"{DATA_DIR}/state_county_tract_puma.csv",
        expand(f"{DATA_DIR}/tl_2025_{{zip}}_addr.dbf.iso.xml", zip=fod_config.zips),
        expand(f"{DATA_DIR}/tl_2025_{{fips}}_tract.shp", fips=fod_config.state_fips),
        expand(f"{DATA_DIR}/tl_2024_{{block_group_fips}}_bg.shp", block_group_fips=fod_config.block_group_fips),
        f"{DATA_DIR}/combined_block_groups.shp",  # Add parameter or whatever for block_group_fips
        f"{DATA_DIR}/FY2025_All_Contracts_Full_20260306.csv",



rule download_tiger_tract:
    resources:
        census_download=1
    output: f"{DATA_DIR}/tl_2025_{{fips}}_tract.zip"
    shell:
        "sleep $((5 + RANDOM % 10)) && "
        f"  {CENSUS_WGET} --timeout={SHORT_TIMEOUT_SECONDS} --tries=1"
        "    'https://www2.census.gov/geo/tiger/TIGER2025/TRACT/tl_2025_{wildcards.fips}_tract.zip'"
        "    -O {output}"


rule extract_tiger_tract:
    input: f"{DATA_DIR}/tl_2025_{{fips}}_tract.zip"
    output: f"{DATA_DIR}/tl_2025_{{fips}}_tract.shp"
    shell:
        "unzip -o {input} -d \"{DATA_DIR}/\""


rule download_tiger_addr:
    resources:
        census_download=1
    output: f"{DATA_DIR}/tl_2025_{{zip}}_addr.zip"
    shell:
        "sleep $((5 + RANDOM % 10)) && "
        f"  {CENSUS_WGET} --timeout={SHORT_TIMEOUT_SECONDS} --tries=1"
        "    'https://www2.census.gov/geo/tiger/TIGER2025/ADDR/tl_2025_{wildcards.zip}_addr.zip'"
        "    -O {output} "


rule download_tiger_block_groups:
    resources:
        census_download=1
    output: f"{DATA_DIR}/tl_2024_{{block_group_fips}}_bg.zip"
    shell:
        "sleep $((5 + RANDOM % 10)) && "
        f"  {CENSUS_WGET} --timeout={SHORT_TIMEOUT_SECONDS} --tries=1"
        "    'https://www2.census.gov/geo/tiger/TIGER2024/BG/tl_2024_{wildcards.block_group_fips}_bg.zip'"
        "    -O {output} "

rule extract_tiger_block_groups:
    input: f"{DATA_DIR}/tl_2024_{{block_group_fips}}_bg.zip"
    output: f"{DATA_DIR}/tl_2024_{{block_group_fips}}_bg.shp"
    shell:
        "unzip -o {input} -d \"{DATA_DIR}/\""

rule extract_tiger_addr:
    input: f"{DATA_DIR}/tl_2025_{{zip}}_addr.zip"
    output: f"{DATA_DIR}/tl_2025_{{zip}}_addr.dbf.iso.xml"
    shell:
        "unzip -o {input} -d \"{DATA_DIR}/\""

rule download_tract_puma_crosswalk:
    resources:
        census_download=1
    output: f"{DATA_DIR}/state_county_unedited.txt"
    shell:
        f"  {CENSUS_WGET} --timeout={SHORT_TIMEOUT_SECONDS} --tries=1"
        "    'https://www2.census.gov/geo/docs/maps-data/data/rel2020/2020_Census_Tract_to_2020_PUMA.txt'"
        "    -O {output}"


rule process_tract_puma_crosswalk:
    """Strip UTF-8 BOM and normalise Windows line endings."""
    input: f"{DATA_DIR}/state_county_unedited.txt"
    output: f"{DATA_DIR}/state_county_tract_puma.csv"
    shell:
        r"sed 's/^\xEF\xBB\xBF//' {input} | dos2unix > {output}"

rule download_osm:
    output: f"{DATA_DIR}/us-latest.osm.pbf"
    shell:
        "sleep $((5 + RANDOM % 10)) && "
        "wget --timeout=3600 --tries=3 --waitretry=60"
        " 'https://download.geofabrik.de/north-america/us-latest.osm.pbf'"
        " -O {output}"


rule extract_osm_nodes:
    """Parse PBF with osmium and write longitude/latitude/encoded_tags/id CSV."""
    input: f"{DATA_DIR}/us-latest.osm.pbf"
    output: f"{DATA_DIR}/united_states_nodes.csv"
    resources:
        mem_gb=8
    shell:
        f"DATA_DIR={DATA_DIR} uv run python {SCRIPTS}/extract_osm_nodes.py"

rule filter_wikidata_us_points:
    """Keep only entities whose coordinates fall within U.S. state boundaries."""
    input:
        f"{DATA_DIR}/wikidata_compressed.json.bz2",
        f"{DATA_DIR}/tl_2024_us_state.shp",
    output: f"{DATA_DIR}/wikidata_us_points.json"
    shell:
        f"DATA_DIR={DATA_DIR} uv run python '{SCRIPTS}/filter_us_nodes.py'"


rule download_cjars:
    resources:
        census_download=1
    output: f"{DATA_DIR}/cjars_joe_2022_co.csv.zip"
    shell:
        "sleep $((5 + RANDOM % 10)) && "
        f"  {CENSUS_WGET} --timeout={SHORT_TIMEOUT_SECONDS} --tries=1"
        "    'https://www2.census.gov/programs-surveys/cjars/datasets/2022/cjars_joe_2022_co.csv.zip'"
        "    -O {output} "


rule extract_cjars:
    input: f"{DATA_DIR}/cjars_joe_2022_co.csv.zip"
    output: f"{DATA_DIR}/output/cjars_joe_2022_co.csv"
    shell:
        "unzip -o {input} -d \"{DATA_DIR}/\""


rule download_tiger_state:
    resources:
        census_download=1
    output: temp(f"{DATA_DIR}/us_state_boundaries.zip")
    shell:
        "sleep $((5 + RANDOM % 10)) && "
        f"  {CENSUS_WGET} --timeout={SHORT_TIMEOUT_SECONDS} --tries=1"
        "    'https://www2.census.gov/geo/tiger/TIGER2024/STATE/tl_2024_us_state.zip'"
        "    -O {output} "


rule extract_tiger_state_boundaries:
    input: f"{DATA_DIR}/us_state_boundaries.zip"
    output: f"{DATA_DIR}/tl_2024_us_state.shp"
    shell:
        "unzip -o {input} -d \"{DATA_DIR}/\""


rule download_filter_wikidata:
    """Stream-download the full dump, filter to geopoint entities, recompress."""
    output: f"{DATA_DIR}/wikidata_compressed.json.bz2"
    shell:
        "wget 'https://dumps.wikimedia.org/wikidatawiki/entities/latest-all.json.bz2'"
        " -O -"
        " | bunzip2 -c"
        f" | uv run python '{SCRIPTS}/compress_wikidata.py'"
        " | bzip2 -c"
        " > {output}"


rule download_tiger_puma:
    resources:
        census_download=1
    output:
        f"{DATA_DIR}/tl_2024_{{puma_state_fips}}_puma20.zip"
    params:
        url = "https://www2.census.gov/geo/tiger/TIGER2024/PUMA20/tl_2024_{puma_state_fips}_puma20.zip"
    shell:
        "sleep $((5 + RANDOM % 10)) && "
        f"  {CENSUS_WGET} --timeout={SHORT_TIMEOUT_SECONDS} --tries=1"
        "    '{params.url}'"
        "    -O {output}"

rule unzip_tiger_puma:
    input:
        f"{DATA_DIR}/tl_2024_{{puma_state_fips}}_puma20.zip"
    output:
        f"{DATA_DIR}/tl_2024_{{puma_state_fips}}_puma20.shp"
    shell:
        "unzip -o {input} -d \"{DATA_DIR}/\""

rule concatenate_tiger_puma:
    input: expand(f"{DATA_DIR}/tl_2024_{{puma_state_fips}}_puma20.shp", puma_state_fips=fod_config.puma_state_fips)
    output: f"{DATA_DIR}/puma_combined.shp"
    shell:
        f"DATA_DIR={DATA_DIR} uv run python '{SCRIPTS}/concatenate_puma_shape_files.py'"

# ---------------------------------------------------------------------------
# State-specific development subsets
# ---------------------------------------------------------------------------
# Usage:
#   snakemake --cores 4 georgia_dev     # Build Georgia development dataset
#   snakemake --cores 4 state_contracts STATE_FIPS=06  # Build any state
# ---------------------------------------------------------------------------

rule georgia_dev:
    """Complete Georgia development dataset: contracts + TIGER geometries."""
    input:
        f"{DATA_DIR}/contracts_state_{GEORGIA_FIPS}.csv",
        f"{DATA_DIR}/tl_2025_{GEORGIA_FIPS}_tract.shp",
        f"{DATA_DIR}/tl_2024_{GEORGIA_FIPS}_bg.shp",
        f"{DATA_DIR}/tl_2024_{GEORGIA_FIPS}_puma20.shp",
        f"{DATA_DIR}/state_county_tract_puma.csv",

rule extract_state_contracts:
    """Filter national contract CSVs to a single state by FIPS code."""
    output: f"{DATA_DIR}/contracts_state_{{state_fips}}.csv"
    params:
        scripts=SCRIPTS
    resources:
        mem_gb=2
    shell:
        "STATE_FIPS={wildcards.state_fips} DATA_DIR={DATA_DIR}"
        f" uv run python '{SCRIPTS}/extract_state_contracts.py'"


rule concatenate_tiger_bg:
    input: expand(f"{DATA_DIR}/tl_2024_{{block_group_fips}}_bg.shp", block_group_fips=fod_config.block_group_fips)
    output: f"{DATA_DIR}/combined_block_groups.shp"
    shell:
        f"DATA_DIR='{DATA_DIR}' uv run python '{SCRIPTS}/concatenate_shape_files.py'"


# ===========================================================================
# USAspending.gov FY2025 All Contracts Full Dataset
# Source: https://files.usaspending.gov/award_data_archive/
# ===========================================================================

rule download_fy2025_contracts:
    resources:
        census_download=1
    output: f"{DATA_DIR}/FY2025_All_Contracts_Full_20260306.zip"
    shell:
        "sleep $((5 + RANDOM % 10)) && "
        f"{CENSUS_WGET} --timeout={SHORT_TIMEOUT_SECONDS} --tries=1"
        "    'https://files.usaspending.gov/award_data_archive/FY2025_All_Contracts_Full_20260306.zip'"
        "    -O {output}"


rule extract_fy2025_contracts:
    input: f"{DATA_DIR}/FY2025_All_Contracts_Full_20260306.zip"
    output: f"{DATA_DIR}/FY2025_All_Contracts_Full_20260306.csv"
    shell:
        "unzip -o {input} -d \"{DATA_DIR}/\""
# NOTE: Legacy commented-out rules for ACS PUMS, SIPP, AHS, and earlier
# TIGER/CJARS/OSM/Wikidata rule versions were removed in this cleanup.
# See git history for the archived rule definitions if needed.
