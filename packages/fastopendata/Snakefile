            ("professional_management", "Professional, Scientific, and Management, and Administrative and Waste Management Services", "7270-7790"),
            ("education_healthcare", "Educational Services, and Health Care and Social Assistance", "7860-8470"),
            ("arts_entertainment_food", "Arts, Entertainment, and Recreation, and Accommodation and Food Services", "8561-8690"),
            ("other_services", "Other Services (except Public Administration)", "8770-9290"),
            ("public_administration", "Public Administration", "9370-9590"),
