        " done"


# ===========================================================================
# Dataset 6: SIPP 2023 — public use file (person-level)
# Source: https://www2.census.gov/programs-surveys/sipp/data/datasets/2023/
# ===========================================================================

rule download_sipp_puf:
    output: temp(f"{DATA_DIR}/pu2023_csv.zip")
    shell:
        CENSUS_WGET +
        " 'https://www2.census.gov/programs-surveys/sipp/data/datasets/2023/pu2023_csv.zip'"
        " -O {output}"


rule extract_sipp_puf:
    input: f"{DATA_DIR}/pu2023_csv.zip"
    output: f"{DATA_DIR}/pu2023.csv"
    shell:
        "unzip -o {input} -d {DATA_DIR}/"


# ===========================================================================
# Dataset 7: SIPP 2023 — replicate weights
# Source: https://www2.census.gov/programs-surveys/sipp/data/datasets/2023/
# ===========================================================================

rule download_sipp_weights:
    output: temp(f"{DATA_DIR}/rw2023_csv.zip")
    shell:
        "wget --no-check-certificate"
        " 'https://www2.census.gov/programs-surveys/sipp/data/datasets/2023/rw2023_csv.zip'"
        " -O {output}"


rule extract_sipp_weights:
    input: f"{DATA_DIR}/rw2023_csv.zip"
    output: f"{DATA_DIR}/rw2023.csv"
    shell:
        "unzip -o {input} -d {DATA_DIR}/"


# ===========================================================================
# Dataset 8: SIPP 2023 — data dictionary / schema (JSON, direct download)
# Source: https://www2.census.gov/programs-surveys/sipp/data/datasets/2023/
# ===========================================================================

rule download_sipp_schema:
    output: f"{DATA_DIR}/pu2023_schema.json"
    shell:
        "wget --no-check-certificate"
        " 'https://www2.census.gov/programs-surveys/sipp/data/datasets/2023/pu2023_schema.json'"
        " -O {output}"


# ===========================================================================
# Dataset 9: American Housing Survey (AHS) 2023 — national PUF
# Two zips: flat CSV data + value labels package.
# Both are extracted into raw_data/ahs_2023/.
# Source: https://www2.census.gov/programs-surveys/ahs/2023/
# ===========================================================================

rule download_ahs_labels:
    output: temp(f"{DATA_DIR}/ahs_2023_labels.zip")
    shell:
        "wget --no-check-certificate"
        " 'https://www2.census.gov/programs-surveys/ahs/2023/AHS%202023%20Value%20Labels%20Package.zip'"
        " -O {output}"


rule download_ahs_data:
    output: temp(f"{DATA_DIR}/ahs_2023_csv.zip")
    shell:
        "wget --no-check-certificate"
        " 'https://www2.census.gov/programs-surveys/ahs/2023/AHS%202023%20National%20PUF%20v1.1%20Flat%20CSV.zip'"
        " -O {output}"


rule extract_ahs:
    input:
        labels = f"{DATA_DIR}/ahs_2023_labels.zip",
        data   = f"{DATA_DIR}/ahs_2023_csv.zip",
    output: touch(f"{DATA_DIR}/.ahs_2023_extracted")
    shell:
        "mkdir -p {DATA_DIR}/ahs_2023 &&"
        " unzip -o {input.labels} -d {DATA_DIR}/ahs_2023/ &&"
        " unzip -o {input.data}   -d {DATA_DIR}/ahs_2023/"


# ===========================================================================
# Dataset 10: CJARS 2022 — county-level job offers
# Source: https://www2.census.gov/programs-surveys/cjars/datasets/2022/
# ===========================================================================

rule download_cjars:
    output: temp(f"{DATA_DIR}/cjars_joe_2022_co.csv.zip")
    shell:
        "wget --no-check-certificate"
        " 'https://www2.census.gov/programs-surveys/cjars/datasets/2022/cjars_joe_2022_co.csv.zip'"
        " -O {output}"


rule extract_cjars:
    input: f"{DATA_DIR}/cjars_joe_2022_co.csv.zip"
    output: f"{DATA_DIR}/cjars_joe_2022_co.csv"
    shell:
        "unzip -o {input} -d {DATA_DIR}/"


# ===========================================================================
# Dataset 11: TIGER/Line 2024 — PUMA shapefiles (all states/territories)
# Downloaded via recursive wget, then extracted, then merged.
# Source: https://www2.census.gov/geo/tiger/TIGER2024/PUMA20/
#
# NOTE: wget mirrors into raw_data/geo/tiger/TIGER2024/PUMA20/ due to -nH.
# ===========================================================================

rule download_tiger_puma:
    output: touch(f"{DATA_DIR}/.tiger_puma_downloaded")
    shell:
        "wget --no-check-certificate -e robots=off -w 3"
        " --user-agent='Mozilla/4.0 (compatible; MSIE 6.0; Windows NT 5.1; SV1)'"
        " --no-cache"
        " --header='referer: https://www2.census.gov/programs-surveys/acs/data/pums/2027/'"
        f" -P {DATA_DIR}/ -nH --recursive --no-parent"
        " 'https://www2.census.gov/geo/tiger/TIGER2024/PUMA20/'"


rule extract_tiger_puma:
    input: f"{DATA_DIR}/.tiger_puma_downloaded"
    output: touch(f"{DATA_DIR}/.tiger_puma_extracted")
    shell:
        f"DATA_DIR={DATA_DIR} bash {SCRIPTS}/extract_puma_shape_files.sh"


rule concatenate_tiger_puma:
    input: f"{DATA_DIR}/.tiger_puma_extracted"
    output: f"{DATA_DIR}/puma_combined.shp"
    shell:
        f"DATA_DIR={DATA_DIR} uv run python {SCRIPTS}/concatenate_puma_shape_files.py"


# ===========================================================================
# Dataset 12: TIGER/Line 2024 — U.S. state boundaries
# Required by filter_us_nodes.py (point-in-polygon against state polygons).
# Source: https://www2.census.gov/geo/tiger/TIGER2024/STATE/
# ===========================================================================

rule download_tiger_state:
    output: temp(f"{DATA_DIR}/us_state_boundaries.zip")
    shell:
        CENSUS_WGET +
        " 'https://www2.census.gov/geo/tiger/TIGER2024/STATE/tl_2024_us_state.zip'"
        " -O {output}"


rule extract_tiger_state:
    input: f"{DATA_DIR}/us_state_boundaries.zip"
    output: f"{DATA_DIR}/tl_2024_us_state.shp"
    shell:
        "unzip -o {input} -d {DATA_DIR}/"


# ===========================================================================
# Dataset 13: TIGER/Line 2025 — Census tracts (wildcard rule, one per state)
# Source: https://www2.census.gov/geo/tiger/TIGER2025/TRACT/
# ===========================================================================

rule download_tiger_tract:
    output: temp(f"{DATA_DIR}/tl_2025_{{fips}}_tract.zip")
    shell:
        "wget --no-check-certificate"
        " 'https://www2.census.gov/geo/tiger/TIGER2025/TRACT/tl_2025_{wildcards.fips}_tract.zip'"
        " -O {output}"


rule extract_tiger_tract:
    input: f"{DATA_DIR}/tl_2025_{{fips}}_tract.zip"
    output: f"{DATA_DIR}/tl_2025_{{fips}}_tract.shp"
    shell:
        "unzip -o {input} -d {DATA_DIR}/"


# ===========================================================================
# Dataset 14: TIGER/Line 2025 — Address features (wildcard rule, one per state)
# Source: https://www2.census.gov/geo/tiger/TIGER2025/ADDR/
# ===========================================================================

rule download_tiger_addr:
    output: temp(f"{DATA_DIR}/tl_2025_{{fips}}_addr.zip")
    shell:
        "wget --no-check-certificate"
        " 'https://www2.census.gov/geo/tiger/TIGER2025/ADDR/tl_2025_{wildcards.fips}_addr.zip'"
        " -O {output}"


rule extract_tiger_addr:
    input: f"{DATA_DIR}/tl_2025_{{fips}}_addr.zip"
    output: f"{DATA_DIR}/tl_2025_{{fips}}_addr.shp"
    shell:
        "unzip -o {input} -d {DATA_DIR}/"


# ===========================================================================
# Dataset 15: TIGER/Line 2024 — Census block groups (all states/territories)
# Downloaded via recursive wget, extracted, then merged via concatenate_shape_files.py.
# Source: https://www2.census.gov/geo/tiger/TIGER2024/BG/
#
# NOTE: concatenate_shape_files.py (when run as __main__) picks up ALL .shp
# files present in DATA_DIR and merges them into combined.shp, selecting
# columns [BLKGRPCE, GEOID, geometry].  Run this rule before other per-state
# shapefiles (tracts, addr) land in DATA_DIR if a clean BG-only merge is needed.
# ===========================================================================

rule download_tiger_bg:
    output: touch(f"{DATA_DIR}/.tiger_bg_downloaded")
    shell:
        "wget --no-check-certificate -e robots=off"
        " --user-agent='Mozilla/4.0 (compatible; MSIE 6.0; Windows NT 5.1; SV1)'"
        f" -P {DATA_DIR}/ -nH --recursive --no-parent"
        " 'https://www2.census.gov/geo/tiger/TIGER2024/BG/'"


rule extract_tiger_bg:
    input: f"{DATA_DIR}/.tiger_bg_downloaded"
    output: touch(f"{DATA_DIR}/.tiger_bg_extracted")
    shell:
        "for zipfile in {DATA_DIR}/geo/tiger/TIGER2024/BG/*.zip;"
        " do unzip -o \"$zipfile\" -d {DATA_DIR}/;"
        " done"


rule concatenate_tiger_bg:
    input: f"{DATA_DIR}/.tiger_bg_extracted"
    output: f"{DATA_DIR}/combined.shp"
    shell:
        f"DATA_DIR={DATA_DIR} uv run python {SCRIPTS}/concatenate_shape_files.py"


# ===========================================================================
# Dataset 16: OpenStreetMap — U.S. extract (.osm.pbf)
# ~10 GB download; the PBF is consumed once to produce a CSV of point nodes.
# Source: https://download.geofabrik.de/north-america/
# License: ODbL 1.0 — attribution required
# ===========================================================================

rule download_osm:
    output: f"{DATA_DIR}/us-latest.osm.pbf"
    shell:
        "wget 'https://download.geofabrik.de/north-america/us-latest.osm.pbf'"
        " -O {output}"


rule extract_osm_nodes:
    """Parse PBF with osmium and write longitude/latitude/encoded_tags/id CSV."""
    input: f"{DATA_DIR}/us-latest.osm.pbf"
    output: f"{DATA_DIR}/united_states_nodes.csv"
    shell:
        f"DATA_DIR={DATA_DIR} uv run python {SCRIPTS}/extract_osm_nodes.py"


# ===========================================================================
# Dataset 17: Wikidata — full entity dump, filtered to U.S. geopoints
# The raw dump is ~100 GB uncompressed; streamed through compress_wikidata.py
# without materialising the decompressed data on disk.
# Source: https://dumps.wikimedia.org/wikidatawiki/entities/
# License: CC0 1.0
# ===========================================================================

rule download_filter_wikidata:
    """Stream-download the full dump, filter to geopoint entities, recompress."""
    output: f"{DATA_DIR}/wikidata_compressed.json.bz2"
    shell:
        "wget 'https://dumps.wikimedia.org/wikidatawiki/entities/latest-all.json.bz2'"
        " -O -"
        " | bunzip2 -c"
        f" | uv run python {SCRIPTS}/compress_wikidata.py"
        " | bzip2 -c"
        " > {output}"


rule filter_wikidata_us_points:
    """Keep only entities whose coordinates fall within U.S. state boundaries."""
    input:
        wikidata  = f"{DATA_DIR}/wikidata_compressed.json.bz2",
        state_shp = f"{DATA_DIR}/tl_2024_us_state.shp",
    output: f"{DATA_DIR}/wikidata_us_points.json"
    shell:
        f"DATA_DIR={DATA_DIR} uv run python {SCRIPTS}/filter_us_nodes.py"
