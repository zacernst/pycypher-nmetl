rule filter_wikidata:
    """Stream-download the full dump, filter to geopoint entities, recompress."""
    input: f"{DATA_DIR}/latest-all.json.bz2"
    output: f"{DATA_DIR}/wikidata_compressed.json.bz2"
    shell:
        "cat {input} | bunzip2 -c"
        f" | uv run python '{SCRIPTS}/compress_wikidata.py'"
        " | bzip2 -c"
        " > {output}"


