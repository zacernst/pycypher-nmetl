            ("construction", "Construction", "770"),
            ("manufacturing", "Manufacturing", "1070-3990"),
            ("wholesale_trade", "Wholesale Trade", "4070-4590"),
            ("retail_trade", "Retail Trade", "4670-5791"),
            ("transportation_utilities", "Transportation and Warehousing, and Utilities", "570-690,6070-6390"),
            ("information", "Information", "6471-6781"),
