# ===========================================================================
# Dataset 13: TIGER/Line 2025 — Census tracts (wildcard rule, one per state)
# Source: https://www2.census.gov/geo/tiger/TIGER2025/TRACT/
# ===========================================================================

rule download_tiger_tract:
    resources:
        census_download=1
    output: temp(f"{DATA_DIR}/tl_2025_{{fips}}_tract.zip")
    shell:
        "sleep $((5 + RANDOM % 10)) && "
        "for i in {{1..3}}; do "
        "  wget --wait=30 --random-wait --timeout={SHORT_TIMEOUT_SECONDS} --tries=1"
        "    'https://www2.census.gov/geo/tiger/TIGER2025/TRACT/tl_2025_{wildcards.fips}_tract.zip'"
        "    -O {output} && "
        "  if [ -s {output} ] && unzip -t {output} >/dev/null 2>&1; then "
        "    echo 'Download of {output} successful and validated'; break; "
        "  else "
        "    echo 'Download of {output} failed validation (corrupted or empty), retrying...'; "
        "    rm -f {output}; "
        "  fi; "
        "  sleep $((30 * i)); "
        "done || "
        "(echo 'All download attempts failed for {output}, creating empty zip as placeholder'; "
        " uv run python -c \"import zipfile; z=zipfile.ZipFile('{output}', 'w'); z.close()\")"


rule extract_tiger_tract:
    input: f"{DATA_DIR}/tl_2025_{{fips}}_tract.zip"
    output: f"{DATA_DIR}/tl_2025_{{fips}}_tract.shp"
    shell:
        "if unzip -t {input} >/dev/null 2>&1 && [ $(unzip -l {input} 2>/dev/null | wc -l) -gt 3 ]; then "
        "  unzip -o {input} -d \"{DATA_DIR}/\"; "
        "else "
        "  echo 'Skipping extraction of {input} (empty or unavailable file)'; "
        "  touch {output}; "
        "fi"


# ===========================================================================
# Dataset 14: TIGER/Line 2025 — Address features (wildcard rule, one per state)
# Source: https://www2.census.gov/geo/tiger/TIGER2025/ADDR/
# ===========================================================================

rule download_tiger_addr:
    resources:
        census_download=1
    output: temp(f"{DATA_DIR}/tl_2025_{{zips}}_addr.zip")
    shell:
        "sleep $((5 + RANDOM % 10)) && "
        "for i in {{1..3}}; do "
        "  wget --wait=30 --random-wait --timeout={SHORT_TIMEOUT_SECONDS} --tries=1"
        "    'https://www2.census.gov/geo/tiger/TIGER2025/ADDR/tl_2025_{wildcards.zips}_addr.zip'"
        "    -O {output} && "
        "  if [ -s {output} ] && unzip -t {output} >/dev/null 2>&1; then "
        "    echo 'Download of {output} successful and validated'; break; "
        "  else "
        "    echo 'Download of {output} failed validation (corrupted or empty), retrying...'; "
        "    rm -f {output}; "
        "  fi; "
        "  sleep $((BACKOFF * i)); "
        "done || "
        "(echo 'All download attempts failed for {output}, creating empty zip as placeholder'; "
        " uv run python -c \"import zipfile; z=zipfile.ZipFile('{output}', 'w'); z.close()\")"


rule extract_tiger_addr:
    input: f"{DATA_DIR}/tl_2025_{{zips}}_addr.zip"
    output: f"{DATA_DIR}/tl_2025_{{zips}}_addr.dbf.iso.xml"
    shell:
        "if unzip -t {input} >/dev/null 2>&1 && [ $(unzip -l {input} 2>/dev/null | wc -l) -gt 3 ]; then "
        "  unzip -o {input} -d \"{DATA_DIR}/\"; "
        "else "
        "  echo 'Skipping extraction of {input} (empty or unavailable file)'; "
        "  touch {output}; "
        "fi"


# ===========================================================================
# Dataset 15: TIGER/Line 2024 — Census block groups (all states/territories)
# Downloaded via recursive wget, extracted, then merged via concatenate_shape_files.py.
# Source: https://www2.census.gov/geo/tiger/TIGER2024/BG/
#
# NOTE: concatenate_shape_files.py (when run as __main__) picks up ALL .shp
# files present in DATA_DIR and merges them into combined.shp, selecting
# columns [BLKGRPCE, GEOID, geometry].  Run this rule before other per-state
# shapefiles (tracts, addr) land in DATA_DIR if a clean BG-only merge is needed.
# ===========================================================================

rule download_tiger_bg:
    resources:
        census_download=1
    output: f"{DATA_DIR}/.tiger_bg_downloaded"
    shell:
        "sleep $((10 + RANDOM % 15)) && "
        "for i in {{1..3}}; do "
        "  echo 'Starting block group download attempt $i...' && "
        "  mkdir -p \"{DATA_DIR}/bg_temp\" && "
        f"  {CENSUS_WGET} --timeout={SHORT_TIMEOUT_SECONDS} --tries=1"
        "    'https://www2.census.gov/geo/tiger/TIGER2024/BG/'"
        "    -O \"{DATA_DIR}/bg_temp/bg_index.html\" && "
        "  echo 'Downloaded directory index, extracting file list...' && "
        "  grep -o 'href=\"tl_[0-9_]*bg\\.zip\"' \"{DATA_DIR}/bg_temp/bg_index.html\" |"
        "    sed 's/href=\"//' | sed 's/\"//' > \"{DATA_DIR}/bg_temp/bg_files.txt\" && "
        "  echo 'Found $(cat \"{DATA_DIR}/bg_temp/bg_files.txt\" | wc -l) block group files to download' && "
        "  success=true && "
        "  while IFS= read -r filename || [[ -n \"$filename\" ]]; do "
        "    echo \"Downloading $filename...\" && "
        "    sleep $((5 + RANDOM % 10)) && "
        f"    {CENSUS_WGET} --timeout={SHORT_TIMEOUT_SECONDS} --tries=1"
        "      \"https://www2.census.gov/geo/tiger/TIGER2024/BG/$filename\""
        "      -O \"{DATA_DIR}/$filename\" && "
        "    unzip -t \"{DATA_DIR}/$filename\" >/dev/null 2>&1 && "
        "    echo \"Successfully downloaded and validated $filename\" || "
        "    (echo \"Failed to download or validate $filename\" && success=false && break); "
        "  done < \"{DATA_DIR}/bg_temp/bg_files.txt\" && "
        "  rm -rf \"{DATA_DIR}/bg_temp\" && "
        "  if [ \"$success\" = true ]; then "
        "    (echo 'All block group files downloaded successfully'; touch {output}; break); "
        "  else "
        "    (echo 'Block group download attempt $i failed' && rm -f \"{DATA_DIR}\"/tl_*bg.zip); "
        "  fi || "
        "  (echo 'Block group download attempt $i failed, waiting before retry...' && sleep $((60 * i))); "
        "done || "
        "(echo 'All block group download attempts failed'; exit 1)"


rule extract_tiger_bg:
    input: f"{DATA_DIR}/.tiger_bg_downloaded"
    output: touch(f"{DATA_DIR}/.tiger_bg_extracted")
    shell:
        "for zipfile in \"{DATA_DIR}\"/geo/tiger/TIGER2024/BG/*.zip;"
        " do unzip -o \"$zipfile\" -d \"{DATA_DIR}/\";"
        " done"


rule concatenate_tiger_bg:
    input: f"{DATA_DIR}/.tiger_bg_extracted"
    output: f"{DATA_DIR}/combined.shp"
    shell:
        f"DATA_DIR='{DATA_DIR}' uv run python '{SCRIPTS}/concatenate_shape_files.py'"


# ===========================================================================
# Dataset 16: OpenStreetMap — U.S. extract (.osm.pbf)
# ~10 GB download; the PBF is consumed once to produce a CSV of point nodes.
# Source: https://download.geofabrik.de/north-america/
# License: ODbL 1.0 — attribution required
# ===========================================================================

rule download_osm:
    output: f"{DATA_DIR}/us-latest.osm.pbf"
    shell:
        "sleep 2 && wget 'https://download.geofabrik.de/north-america/us-latest.osm.pbf'"
        " -O {output}"


rule extract_osm_nodes:
    """Parse PBF with osmium and write longitude/latitude/encoded_tags/id CSV."""
    input: f"{DATA_DIR}/us-latest.osm.pbf"
    output: f"{DATA_DIR}/united_states_nodes.csv"
    resources:
        mem_gb=8
    shell:
        f"DATA_DIR='{DATA_DIR}' uv run python '{SCRIPTS}/extract_osm_nodes.py'"


# ===========================================================================
# Dataset 17: Wikidata — full entity dump, filtered to U.S. geopoints
# The raw dump is ~100 GB uncompressed; streamed through compress_wikidata.py
# without materialising the decompressed data on disk.
# Source: https://dumps.wikimedia.org/wikidatawiki/entities/
# License: CC0 1.0
# ===========================================================================

rule download_filter_wikidata:
    """Stream-download the full dump, filter to geopoint entities, recompress."""
    output: f"{DATA_DIR}/wikidata_compressed.json.bz2"
    resources:
        mem_gb=4
    shell:
        "sleep 2 && wget 'https://dumps.wikimedia.org/wikidatawiki/entities/latest-all.json.bz2'"
        " -O -"
        " | bunzip2 -c"
        f" | uv run python '{SCRIPTS}/compress_wikidata.py'"
        " | bzip2 -c"
        " > {output}"


rule filter_wikidata_us_points:
    """Keep only entities whose coordinates fall within U.S. state boundaries."""
    input:
        wikidata  = f"{DATA_DIR}/wikidata_compressed.json.bz2",
        state_shp = f"{DATA_DIR}/tl_2024_us_state.shp",
    output: f"{DATA_DIR}/wikidata_us_points.json"
    resources:
        mem_gb=4
    shell:
        f"DATA_DIR='{DATA_DIR}' uv run python '{SCRIPTS}/filter_us_nodes.py'"
