rule extract_pums_5yr_readme:
    """Extract the ACS 2020-2024 PUMS README PDF from the housing zip into docs/.

    The PDF is present in both the housing and person 5-year zips; we pull it
    from the housing zip since it is the smaller of the two downloads.
    """
    input: f"{DATA_DIR}/csv_hus_5yr.zip"
    output: f"{DOCS_DIR}/ACS2020_2024_PUMS_README.pdf"
    shell:
        "unzip -p {input} ACS2020_2024_PUMS_README.pdf > {output}"

rule add_puma_fips_to_psam_pus_5yr:
    input: f"{DATA_DIR}/psam_pus_5yr_tmp.parquet"
    output: f"{DATA_DIR}/psam_pus_5yr.parquet"
    shell:
        f"uv run duckdb -c \"SET preserve_insertion_order = false; SET threads = 1; SET memory_limit = '6GB'; SET temp_directory = '/tmp'; COPY (SELECT *, STATE || PUMA AS PUMA_FIPS FROM '{DATA_DIR}/psam_pus_5yr_tmp.parquet') TO '{DATA_DIR}/psam_pus_5yr.parquet' (FORMAT PARQUET, COMPRESSION 'ZSTD');\""


rule download_food_access:
    output: f"{DATA_DIR}/food_access.zip"
    shell:
        f"wget https://www.ers.usda.gov/media/5627/food-access-research-atlas-data-download-2019.zip?v=21058 -O {DATA_DIR}/food_access.zip"


rule extract_food_access:
    input: f"{DATA_DIR}/food_access.zip"
    output: f"{DATA_DIR}/Food Access Research Atlas.csv"
    shell:
        "unzip -o {input} -d \"{DATA_DIR}/\""


rule convert_food_access_to_parquet:
    input: f"{DATA_DIR}/Food Access Research Atlas.csv"
    output: f"{DATA_DIR}/food_access.parquet"
    run:
        import pandas as pd
        df = pd.read_csv(input[0], encoding="latin-1", dtype=str)
        df["TRACT_FIPS"] = (
            df["CensusTract"]
            .astype(str)
            .str.split(".")
            .str[0]
            .str.zfill(11)
        )
        df = df.drop(columns=["CensusTract"])
        df.to_parquet(output[0], index=False)


