# =============================================================================
# Snakefile — fastopendata data pipeline
#
# Downloads and processes all 17 source datasets used by fastopendata.
#
# Run from packages/fastopendata/:
#   snakemake --cores 4
#
# Override data directory:
#   snakemake --cores 4 --config data_dir=/mnt/data/fastopendata
#   # OR set environment variable: DATA_DIR=/mnt/data/fastopendata snakemake --cores 4
#
# Download only a subset of targets by naming them explicitly:
#   snakemake --cores 4 raw_data/psam_pus.csv raw_data/pu2023.csv
#
# Requirements: wget, unzip, dos2unix, bunzip2, bzip2, uv
# =============================================================================

from pathlib import Path
import sys

# Add package to path for config import
sys.path.insert(0, str(Path(__file__).parent / "src"))

from fastopendata.config import config as fod_config

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

# Use centralized configuration with Snakemake config override
if "data_dir" in config:
    DATA_DIR = config["data_dir"]
else:
    DATA_DIR = fod_config.data_dir

SCRIPTS = fod_config.scripts_path

# State + territory FIPS codes from centralized config
STATE_FIPS = fod_config.state_fips

# wget flags from centralized config
CENSUS_WGET = fod_config.get_census_wget_flags()

ZIPS = fod_config.zips

SHORT_TIMEOUT_SECONDS = fod_config.short_timeout_seconds
LONG_TIMEOUT_SECONDS = fod_config.long_timeout_seconds

BACKOFF = 120

# ---------------------------------------------------------------------------
# all — every terminal artifact in the pipeline
# ---------------------------------------------------------------------------


rule all:
    input:
        # 1  — Census Tract-to-PUMA crosswalk
        f"{DATA_DIR}/state_county_tract_puma.csv",
        # 2  — ACS PUMS 2023 1-year, persons
        f"{DATA_DIR}/psam_pus.csv",
        # 3  — ACS PUMS 2023 5-year, persons
        f"{DATA_DIR}/psam_p.csv",
        # 4  — ACS PUMS 2023 1-year, housing
        f"{DATA_DIR}/psam_hus.csv",
        # 5  — ACS PUMS 2023 5-year, housing
        f"{DATA_DIR}/psam_h.csv",
        # 6  — SIPP 2023 public use file
        f"{DATA_DIR}/pu2023.csv",
        # 7  — SIPP 2023 replicate weights
        f"{DATA_DIR}/rw2023.csv",
        # 8  — SIPP 2023 data dictionary
        f"{DATA_DIR}/pu2023_schema.json",
        # 9  — AHS 2023 (sentinel: extraction directory)
        f"{DATA_DIR}/.ahs_2023_extracted",
        # 10 — CJARS 2022 county job offers
        f"{DATA_DIR}/cjars_joe_2022_co.csv",
        # 11 — TIGER/Line 2024 PUMA shapefiles, merged
        f"{DATA_DIR}/puma_combined.shp",
        # 12 — TIGER/Line 2024 U.S. state boundaries
        f"{DATA_DIR}/tl_2024_us_state.shp",
        # 13 — TIGER/Line 2025 census tracts, one shapefile per state/territory
        expand(f"{DATA_DIR}/tl_2025_{{fips}}_tract.shp", fips=STATE_FIPS),
        # 14 — TIGER/Line 2025 address features, one shapefile per state/territory
        expand(f"{DATA_DIR}/tl_2025_{{zips}}_addr.dbf.iso.xml", zips=ZIPS),
        # 15 — TIGER/Line 2024 block groups, merged
        f"{DATA_DIR}/combined.shp",
        # 16 — OpenStreetMap U.S. nodes extracted to CSV
        f"{DATA_DIR}/united_states_nodes.csv",
        # 17 — Wikidata U.S. geopoint entities
        f"{DATA_DIR}/wikidata_us_points.json",


# ===========================================================================
# Dataset 1: Census Tract-to-PUMA crosswalk (2020)
# Source: https://www2.census.gov/geo/docs/maps-data/data/rel2020/
# ===========================================================================

rule download_tract_puma_crosswalk:
    resources:
        census_download=1
    output: temp(f"{DATA_DIR}/state_county_unedited.txt")
    shell:
        "sleep $((5 + RANDOM % 10)) && "
        "for i in {{1..3}}; do "
        f"  {CENSUS_WGET} --timeout={SHORT_TIMEOUT_SECONDS} --tries=1"
        "    'https://www2.census.gov/geo/docs/maps-data/data/rel2020/2020_Census_Tract_to_2020_PUMA.txt'"
        "    -O {output} && break || "
        "  (echo 'Tract-PUMA crosswalk download attempt $i failed, waiting before retry...' && sleep $((30 * i))); "
        "done"


rule process_tract_puma_crosswalk:
    """Strip UTF-8 BOM and normalise Windows line endings."""
    input: f"{DATA_DIR}/state_county_unedited.txt"
    output: f"{DATA_DIR}/state_county_tract_puma.csv"
    shell:
        r"sed 's/^\xEF\xBB\xBF//' {input} | dos2unix > {output}"


# ===========================================================================
# Dataset 2: ACS PUMS 2023 — 1-year, person records
# The zip contains psam_pusa.csv + psam_pusb.csv (split alphabetically).
# Source: https://www2.census.gov/programs-surveys/acs/data/pums/2023/1-Year/
# ===========================================================================

rule download_acs_pums_1yr_persons:
    resources:
        census_download=1
    output: temp(f"{DATA_DIR}/csv_pus_1_year.zip")
    shell:
        "sleep $((5 + RANDOM % 10)) && "
        "for i in {{1..3}}; do "
        f"  {CENSUS_WGET} --timeout={SHORT_TIMEOUT_SECONDS} --tries=1"
        "    'https://www2.census.gov/programs-surveys/acs/data/pums/2023/1-Year/csv_pus.zip'"
        "    -O {output} && break || "
        "  (echo 'ACS PUMS 1yr persons download attempt $i failed, waiting before retry...' && sleep $((30 * i))); "
        "done"


rule extract_acs_pums_1yr_persons:
    """Extract and concatenate the two alphabetical halves into psam_pus.csv."""
    input: f"{DATA_DIR}/csv_pus_1_year.zip"
    output: f"{DATA_DIR}/psam_pus.csv"
    shell:
        "unzip -o {input} -d \"{DATA_DIR}/\" &&"
        " head -1 \"{DATA_DIR}/psam_pusa.csv\" > {output} &&"
        " tail -n +2 -q \"{DATA_DIR}/psam_pusa.csv\" \"{DATA_DIR}/psam_pusb.csv\" >> {output}"


# ===========================================================================
# Dataset 3: ACS PUMS 2023 — 5-year, person records
# The zip contains one CSV per state (psam_p01.csv … psam_p56.csv).
# Source: https://www2.census.gov/programs-surveys/acs/data/pums/2023/5-Year/
# ===========================================================================

rule download_acs_pums_5yr_persons:
    resources:
        census_download=1
    output: temp(f"{DATA_DIR}/csv_pus_5_year.zip")
    shell:
        "sleep $((5 + RANDOM % 10)) && "
        "for i in {{1..3}}; do "
        f"  {CENSUS_WGET} --timeout={SHORT_TIMEOUT_SECONDS} --tries=1"
        "    'https://www2.census.gov/programs-surveys/acs/data/pums/2023/5-Year/csv_pus.zip'"
        "    -O {output} && break || "
        "  (echo 'ACS PUMS 5yr persons download attempt $i failed, waiting before retry...' && sleep $((30 * i))); "
        "done"


rule extract_merge_acs_pums_5yr_persons:
    """Extract per-state CSVs, then concatenate into a single national file."""
    input: f"{DATA_DIR}/csv_pus_5_year.zip"
    output: f"{DATA_DIR}/psam_p.csv"
    shell:
        "unzip -o {input} -d \"{DATA_DIR}/\" &&"
        " head -1 $(ls \"{DATA_DIR}\"/psam_p??.csv | sort | head -1) > {output} &&"
        " for f in $(ls \"{DATA_DIR}\"/psam_p??.csv | sort);"
        "   do tail -n +2 \"$f\" >> {output};"
        " done"


