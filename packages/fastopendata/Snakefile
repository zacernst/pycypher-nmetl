rule generate_language_groups:
    """Write the 7-row ACS language family group reference CSV.

    Groups map the 2024 ACS PUMS LANP codes to broad language families
    (from ACSPUMS2024CodeLists.xls Language sheet). The lang_group_code
    values match the language_group derived column added to psam_pus
    in the ETL query. english_only covers persons with NULL LANP
    (English-only speakers are not assigned a LANP code in ACS PUMS).
    """
    output: f"{DATA_DIR}/language_groups.csv"
    run:
        import csv
        rows = [
            ("lang_group_code", "lang_group_name", "lanp_range"),
            ("english_only", "English Only", "NULL"),
            ("spanish", "Spanish", "1200"),
            ("european", "European Languages (Germanic, Romance, Slavic, Baltic)", "1000-1287 excl. 1200"),
            ("south_central_asian", "South and Central Asian Languages (Indo-Iranian, Dravidian, Turkic)", "1288-1899"),
            ("east_southeast_asian_pacific", "East and Southeast Asian and Pacific Island Languages", "1900-3600"),
            ("middle_eastern_african", "Middle Eastern, North African, and Sub-Saharan African Languages", "4500-9998"),
            ("other_unspecified", "Other and Unspecified Languages", "9999"),
        ]
        with open(output[0], "w", newline="") as f:
            csv.writer(f).writerows(rows)


