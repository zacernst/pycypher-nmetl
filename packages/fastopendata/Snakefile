rule download_rural_urban_codes:
    output: f"{DATA_DIR}/rural_urban_county_codes.csv"
    shell:
        "sleep $((5 + RANDOM % 10)) && "
        f"  {CENSUS_WGET} --timeout={SHORT_TIMEOUT_SECONDS} --tries=100"
        "   'https://www.ers.usda.gov/media/5768/2023-rural-urban-continuum-codes.csv?v=31038'"
        "    -O {output} "


rule pivot_rural_urban_county_codes:
    input: f"{DATA_DIR}/rural_urban_county_codes.csv"
    output: f"{DATA_DIR}/rural_urban_county_codes.parquet"
    run:
        import pandas as pd
        df = pd.read_csv(input[0], encoding="latin-1", dtype={"FIPS": str})
        wide = df.pivot_table(
            index=["FIPS", "State", "County_Name"],
            columns="Attribute",
            values="Value",
            aggfunc="first",
        ).reset_index()
        wide.columns.name = None
        wide = wide.rename(columns={
            "Population_2020": "population_2020",
            "RUCC_2023": "rucc_2023",
            "Description": "rucc_description",
        })
        wide["rucc_2023"] = pd.to_numeric(wide["rucc_2023"], errors="coerce").astype("Int64")
        wide["population_2020"] = pd.to_numeric(wide["population_2020"], errors="coerce").astype("Int64")
        wide.to_parquet(output[0], index=False)


rule extract_cjars:
    input: f"{DATA_DIR}/cjars_joe_2022_co.csv.zip"
    output: f"{DATA_DIR}/output/cjars_joe_2022_co.csv"
    shell:
        f"unzip -o {{input}} -d \"{DATA_DIR}/\""

rule convert_cjars_to_parquet:
    input: f"{DATA_DIR}/output/cjars_joe_2022_co.csv"
    output: f"{DATA_DIR}/output/cjars_joe_2022_co.parquet"
    shell:
        f"uv run duckdb -c \""
        f"SET preserve_insertion_order = false; SET threads = 1; SET memory_limit = '6GB'; SET temp_directory = '/tmp';"
        f"COPY ("
        f"  SELECT"
        f"    RIGHT(geoid, 5) AS county_fips_5,"
        f"    geo_name,"
        f"    state_fips,"
        f"    cj_event_type,"
        f"    cj_event_type_label,"
        f"    offense_type,"
        f"    offense_type_label,"
        f"    age_group,"
        f"    age_group_label,"
        f"    sex,"
        f"    sex_label,"
        f"    race_ethnicity,"
        f"    race_ethnicity_label,"
        f"    outcome_type,"
        f"    outcome_type_label,"
        f"    estimation_type,"
        f"    estimation_type_label,"
        f"    TRY_CAST(statistic AS DOUBLE) AS statistic,"
        f"    RIGHT(geoid, 5) || '_' || cj_event_type || '_' || offense_type || '_' || age_group || '_' || sex || '_' || race_ethnicity || '_' || outcome_type AS record_id"
        f"  FROM read_csv('{DATA_DIR}/output/cjars_joe_2022_co.csv', header=true, nullstr=['', 'NA'])"
        f"  WHERE cj_event_type_label IN ('Felony charge', 'Misdemeanor charge')"
        f"  AND outcome_type_label IN ("
        f"    '% employed in a year',"
        f"    'Average annual employment earnings',"
        f"    '% enrolled in Medicaid',"
        f"    '% receiving Supplemental Security Income',"
        f"    '% receiving HUD rental housing assistance',"
        f"    '% who have died since the event'"
        f"  )"
        f") TO '{DATA_DIR}/output/cjars_joe_2022_co.parquet' (FORMAT PARQUET, COMPRESSION 'ZSTD');\""

