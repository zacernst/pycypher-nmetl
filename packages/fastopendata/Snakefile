# # ===========================================================================
# # Dataset 15: TIGER/Line 2024 — Census block groups (all states/territories)
# # Downloaded via recursive wget, extracted, then merged via concatenate_shape_files.py.
# # Source: https://www2.census.gov/geo/tiger/TIGER2024/BG/
# #
# # NOTE: concatenate_shape_files.py (when run as __main__) picks up ALL .shp
# # files present in DATA_DIR and merges them into combined.shp, selecting
# # columns [BLKGRPCE, GEOID, geometry].  Run this rule before other per-state
# # shapefiles (tracts, addr) land in DATA_DIR if a clean BG-only merge is needed.
# # ===========================================================================
#
# rule download_tiger_bg:
#     resources:
#         census_download=1
#     output: f"{DATA_DIR}/.tiger_bg_downloaded"
#     shell:
#         "sleep $((10 + RANDOM % 15)) && "
#         "for i in {{1..3}}; do "
#         "  echo 'Starting block group download attempt $i...' && "
#         "  mkdir -p \"{DATA_DIR}/bg_temp\" && "
#         f"  {CENSUS_WGET} --timeout={SHORT_TIMEOUT_SECONDS} --tries=1"
#         "    'https://www2.census.gov/geo/tiger/TIGER2024/BG/'"
#         "    -O \"{DATA_DIR}/bg_temp/bg_index.html\" && "
#         "  echo 'Downloaded directory index, extracting file list...' && "
#         "  grep -o 'href=\"tl_[0-9_]*bg\\.zip\"' \"{DATA_DIR}/bg_temp/bg_index.html\" |"
#         "    sed 's/href=\"//' | sed 's/\"//' > \"{DATA_DIR}/bg_temp/bg_files.txt\" && "
#         "  echo 'Found $(cat \"{DATA_DIR}/bg_temp/bg_files.txt\" | wc -l) block group files to download' && "
#         "  success=true && "
#         "  while IFS= read -r filename || [[ -n \"$filename\" ]]; do "
#         "    echo \"Downloading $filename...\" && "
#         "    sleep $((5 + RANDOM % 10)) && "
#         f"    {CENSUS_WGET} --timeout={SHORT_TIMEOUT_SECONDS} --tries=1"
#         "      \"https://www2.census.gov/geo/tiger/TIGER2024/BG/$filename\""
#         "      -O \"{DATA_DIR}/$filename\" && "
#         "    unzip -t \"{DATA_DIR}/$filename\" >/dev/null 2>&1 && "
#         "    echo \"Successfully downloaded and validated $filename\" || "
#         "    (echo \"Failed to download or validate $filename\" && success=false && break); "
#         "  done < \"{DATA_DIR}/bg_temp/bg_files.txt\" && "
#         "  rm -rf \"{DATA_DIR}/bg_temp\" && "
#         "  if [ \"$success\" = true ]; then "
#         "    (echo 'All block group files downloaded successfully'; touch {output}; break); "
#         "  else "
#         "    (echo 'Block group download attempt $i failed' && rm -f \"{DATA_DIR}\"/tl_*bg.zip); "
#         "  fi || "
#         "  (echo 'Block group download attempt $i failed, waiting before retry...' && sleep $((60 * i))); "
#         "done || "
#         "(echo 'All block group download attempts failed'; exit 1)"
