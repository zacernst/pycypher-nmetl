# ===========================================================================
# Dataset 11: TIGER/Line 2024 — PUMA shapefiles (all states/territories)
# Downloaded via recursive wget, then extracted, then merged.
# Source: https://www2.census.gov/geo/tiger/TIGER2024/PUMA20/
#
# NOTE: wget mirrors into raw_data/geo/tiger/TIGER2024/PUMA20/ due to -nH.
# ===========================================================================

rule download_tiger_puma:
    resources:
        census_download=1
    output: f"{DATA_DIR}/.tiger_puma_downloaded"
    shell:
        "sleep $((10 + RANDOM % 15)) && "
        "for i in {{1..3}}; do "
        "  echo 'Starting PUMA download attempt $i...' && "
        "  mkdir -p \"{DATA_DIR}/puma_temp\" && "
        f"  {CENSUS_WGET} --recursive --wait=2 --timeout={LONG_TIMEOUT_SECONDS} --tries=1"
        "    'https://www2.census.gov/geo/tiger/TIGER2024/PUMA20/'"
        "    -O \"{DATA_DIR}/puma_temp/puma_index.html\" && "
        "  echo 'Downloaded directory index, extracting file list...' && "
        "  grep -o 'href=\"tl_[0-9_]*puma20\\.zip\"' \"{DATA_DIR}/puma_temp/puma_index.html\" |"
        "    sed 's/href=\"//' | sed 's/\"//' > \"{DATA_DIR}/puma_temp/puma_files.txt\" && "
        "  echo 'Found $(cat \"{DATA_DIR}/puma_temp/puma_files.txt\" | wc -l) PUMA files to download' && "
        "  success=true && "
        "  while IFS= read -r filename || [[ -n \"$filename\" ]]; do "
        "    echo \"Downloading $filename...\" && "
        "    sleep $((5 + RANDOM % 10)) && "
        f"    {CENSUS_WGET} --timeout={SHORT_TIMEOUT_SECONDS} --tries=1"
        "      \"https://www2.census.gov/geo/tiger/TIGER2024/PUMA20/$filename\""
        "      -O \"{DATA_DIR}/$filename\" && "
        "    unzip -t \"{DATA_DIR}/$filename\" >/dev/null 2>&1 && "
        "    echo \"Successfully downloaded and validated $filename\" || "
        "    (echo \"Failed to download or validate $filename\" && success=false && break); "
        "  done < \"{DATA_DIR}/puma_temp/puma_files.txt\" && "
        "  rm -rf \"{DATA_DIR}/puma_temp\" && "
        "  if [ \"$success\" = true ]; then "
        "    (echo 'All PUMA files downloaded successfully'; touch {output}; break); "
        "  else "
        "    (echo 'PUMA download attempt $i failed' && rm -f \"{DATA_DIR}\"/tl_*puma20.zip); "
        "  fi || "
        "  (echo 'PUMA download attempt $i failed, waiting before retry...' && sleep $((60 * i))); "
        "done || "
        "(echo 'All PUMA download attempts failed'; exit 1)"


rule extract_tiger_puma:
    input: f"{DATA_DIR}/.tiger_puma_downloaded"
    output: touch(f"{DATA_DIR}/.tiger_puma_extracted")
    shell:
        f"DATA_DIR='{DATA_DIR}' bash '{SCRIPTS}/extract_puma_shape_files.sh'"


rule concatenate_tiger_puma:
    input: f"{DATA_DIR}/.tiger_puma_extracted"
    output: f"{DATA_DIR}/puma_combined.shp"
    shell:
        f"DATA_DIR='{DATA_DIR}' uv run python '{SCRIPTS}/concatenate_puma_shape_files.py'"


# ===========================================================================
# Dataset 12: TIGER/Line 2024 — U.S. state boundaries
