queries:
  - id: counties_in_state
    description: "Get all the relationships -- test"
    inline: "MATCH (s:State)<-[:IN]-(c:County) WITH DISTINCT id(s) AS state_name, id(c) AS county_name RETURN state_name, county_name"

  - id: tracts_in_county
    description: "Get all the relationships -- test"
    inline: MATCH (c:County)<-[:IN]-(t:Tract) WITH DISTINCT id(c) AS county_name, id(t) AS tract_name RETURN county_name, tract_name

  - id: num_counties_in_state
    description: "Do a simple test aggregation"
    inline: MATCH (s:State)<-[:IN]-(c:County) WITH DISTINCT s, COUNT(c) AS num_counties SET s.num_counties = num_counties

  - id: over_hundred_counties
    description: "Do a simple test aggregation"
    inline: MATCH (s:State) WITH s, s.num_counties > 100 AS over_hundred_counties SET s.over_hundred_counties = over_hundred_counties

  - id: osm_longitude
    description: "Test retrieving raw longitude value"
    inline: MATCH (o:OSMNode) WITH o.longitude AS longitude, id(o) AS identifier, o SET o.foo = longitude + 1000 WITH identifier, o.foo AS foo, o.decoded_tags AS decoded_tags RETURN identifier, foo, decoded_tags

  - id: decode_tags
    description: "Testing whether we can call a function to decode serialized data"
    inline: MATCH (o:OSMNode) WITH o.encoded_tags AS encoded_tags, o SET o.decoded_tags = decode_serialized(encoded_tags)
    property_types:
      decoded_tags: str

  - id: county_rucc_is_metro
    description: "Flag County nodes in metro areas (RUCC codes 1-3)"
    inline: "MATCH (c:County) WHERE c.rucc_2023 IS NOT NULL WITH c, c.rucc_2023 <= 3 AS is_metro SET c.is_metro = is_metro"
    property_types:
      is_metro: bool

  - id: county_rucc_is_rural
    description: "Flag County nodes that are completely rural (RUCC codes 8-9)"
    inline: "MATCH (c:County) WHERE c.rucc_2023 IS NOT NULL WITH c, c.rucc_2023 >= 8 AS is_rural SET c.is_rural = is_rural"
    property_types:
      is_rural: bool

  - id: county_rucc_classification
    description: "Set a three-way metro/nonmetro_urban/rural classification string on each County node"
    inline: "MATCH (c:County) WHERE c.rucc_2023 IS NOT NULL WITH c, CASE WHEN c.rucc_2023 <= 3 THEN 'metro' WHEN c.rucc_2023 <= 7 THEN 'nonmetro_urban' ELSE 'rural' END AS rucc_class SET c.rucc_class = rucc_class"
    property_types:
      rucc_class: str

  - id: tract_rucc_code
    description: "Propagate county RUCC code and description down to each tract"
    inline: "MATCH (t:Tract)-[:IN]->(c:County) SET t.rucc_2023 = c.rucc_2023, t.rucc_description = c.rucc_description"
    property_types:
      rucc_2023: int

  - id: puma_rucc_stats
    description: "Compute average RUCC score and rural/metro tract fractions for each PUMA"
    inline: "MATCH (pu:PUMA)<-[:IN]-(t:Tract)-[:IN]->(c:County) WHERE c.rucc_2023 IS NOT NULL WITH pu, AVG(toFloat(c.rucc_2023)) AS rucc_avg, SUM(CASE WHEN c.rucc_2023 >= 8 THEN 1 ELSE 0 END) AS rural_tracts, SUM(CASE WHEN c.rucc_2023 <= 3 THEN 1 ELSE 0 END) AS metro_tracts, COUNT(t) AS total_tracts SET pu.rucc_avg = rucc_avg, pu.pct_rural_tracts = toFloat(rural_tracts) / total_tracts, pu.pct_metro_tracts = toFloat(metro_tracts) / total_tracts"

  - id: state_rucc_stats
    description: "Roll up RUCC stats from PUMA to State and count rural and metro counties directly"
    inline: "MATCH (s:State)<-[:IN]-(c:County) WHERE c.rucc_2023 IS NOT NULL WITH s, AVG(toFloat(c.rucc_2023)) AS rucc_avg, SUM(CASE WHEN c.rucc_2023 >= 8 THEN 1 ELSE 0 END) AS rural_county_count, SUM(CASE WHEN c.rucc_2023 <= 3 THEN 1 ELSE 0 END) AS metro_county_count, COUNT(c) AS total_counties SET s.rucc_avg = rucc_avg, s.pct_rural_tracts = toFloat(rural_county_count) / total_counties, s.pct_metro_tracts = toFloat(metro_county_count) / total_counties, s.rural_county_count = rural_county_count, s.metro_county_count = metro_county_count"

  - id: puma_population_1yr
    description: "Count ACS PUMS person records per PUMA as population estimate"
    inline: "MATCH (pu:PUMA)<-[:LIVES_IN]-(p:PersonSurvey) WITH pu, COUNT(p) AS pop_estimate_1yr SET pu.pop_estimate_1yr = pop_estimate_1yr"

  - id: puma_housing_units_1yr
    description: "Count ACS PUMS housing units per PUMA"
    inline: "MATCH (pu:PUMA)<-[:LOCATED_IN]-(h:HousingSurvey) WITH pu, COUNT(h) AS housing_unit_count_1yr SET pu.housing_unit_count_1yr = housing_unit_count_1yr"

  - id: puma_veteran_count_1yr
    description: "Count veteran person records per PUMA"
    inline: "MATCH (pu:PUMA)<-[:LIVES_IN]-(p:PersonSurvey) WHERE p.is_veteran = 1 WITH pu, COUNT(p) AS veteran_count_1yr SET pu.veteran_count_1yr = veteran_count_1yr"

  - id: state_award_count
    description: "Count federal contract award transactions per state by place of performance"
    inline: "MATCH (s:State)<-[:PERFORMED_IN]-(a:FederalAward) WITH s, COUNT(a) AS award_count SET s.award_count = award_count"

  - id: puma_mgmt_count_1yr
