version: "1.0"

functions:
  - module: fastopendata.registered_functions.decoder
    names: [decode_serialized]

sources:
  entities:
    - id: osm_nodes
      uri: "file://${DATA_DIR}/united_states_nodes_tract_crosswalk.parquet"
      entity_type: OSMNode
      id_col: id
      schema_hints:
        longitude: FLOAT
        latitude: FLOAT
        encoded_tags: STRING
        id: INTEGER

    - id: state_crosswalk
      uri: "file://${DATA_DIR}/state_county_tract_puma_crosswalk.csv"
      entity_type: State
      id_col: STATE_FIPS
      schema_hints:
        STATEFP: STRING
        COUNTYFP: STRING
        TRACTFP: STRING
        PUMA5CE: STRING
        STATE_FIPS: STRING
        COUNTY_FIPS: STRING
        TRACT_FIPS: STRING
        PUMA_FIPS: STRING

    - id: county_crosswalk
      uri: "file://${DATA_DIR}/state_county_tract_puma_crosswalk.csv"
      entity_type: County
      id_col: COUNTY_FIPS
      schema_hints:
        STATEFP: STRING
        COUNTYFP: STRING
        TRACTFP: STRING
        PUMA5CE: STRING
        STATE_FIPS: STRING
        COUNTY_FIPS: STRING
        TRACT_FIPS: STRING
        PUMA_FIPS: STRING

    - id: rural_urban_county_codes
      uri: "file://${DATA_DIR}/rural_urban_county_codes.parquet"
      entity_type: County
      id_col: FIPS
      schema_hints:
        FIPS: STRING
        State: STRING
        County_Name: STRING
        population_2020: INTEGER
        rucc_2023: INTEGER
        rucc_description: STRING

    - id: tract_crosswalk
      uri: "file://${DATA_DIR}/state_county_tract_puma_crosswalk.csv"
      entity_type: Tract
      id_col: TRACT_FIPS
      schema_hints:
        STATEFP: STRING
        COUNTYFP: STRING
        TRACTFP: STRING
        PUMA5CE: STRING
        STATE_FIPS: STRING
        COUNTY_FIPS: STRING
        TRACT_FIPS: STRING
        PUMA_FIPS: STRING

    - id: puma_crosswalk
      uri: "file://${DATA_DIR}/state_county_tract_puma_crosswalk.csv"
      entity_type: PUMA
      id_col: PUMA_FIPS
      schema_hints:
        STATEFP: STRING
        COUNTYFP: STRING
        TRACTFP: STRING
        PUMA5CE: STRING
        STATE_FIPS: STRING
        COUNTY_FIPS: STRING
        TRACT_FIPS: STRING
        PUMA_FIPS: STRING

    - id: tract_osm
      uri: "file://${DATA_DIR}/united_states_nodes_tract_crosswalk.csv"
      entity_type: Tract
      id_col: GEOID
      schema_hints:
        GEOID: STRING
        longitude: float
        latitude: float

    - id: psam_housing_survey
