  - id: county_felony_employment_rate
    description: "Share employed in the year of a felony charge, across all offense types, ages, sexes, and races in each County"
    inline: "MATCH (r:CJARSRecord)-[:LOCATED_IN]->(c:County) WHERE r.cj_event_type_label = 'Felony charge' AND r.offense_type_label = 'All offenses' AND r.age_group_label = 'All ages (18+)' AND r.sex_label = 'All sexes' AND r.race_ethnicity_label = 'All races/ethnicities' AND r.outcome_type_label = '% employed in a year' WITH c, AVG(r.statistic) AS felony_employment_rate SET c.felony_employment_rate = felony_employment_rate"
    property_types:
      felony_employment_rate: float

