    - id: person_resides_in_unit
      uri: "file://${DATA_DIR}/psam_pus.parquet"
      relationship_type: RESIDES_IN
      source_entity_type: PersonSurvey
      target_entity_type: HousingSurvey
      source_col: PERSON_ID
      target_col: SERIALNO
      query: "SELECT SERIALNO || '_' || CAST(SPORDER AS VARCHAR) AS PERSON_ID, SERIALNO FROM source"

    - id: person_works_in_occ_group
      uri: "file://${DATA_DIR}/psam_pus.parquet"
      relationship_type: WORKS_IN
      source_entity_type: PersonSurvey
      target_entity_type: OccupationGroup
      source_col: PERSON_ID
      target_col: occ_group
      query: >-
        SELECT PERSON_ID, occ_group FROM (
