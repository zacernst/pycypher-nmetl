    - id: psam_person_survey
      uri: "file://${DATA_DIR}/psam_pus.parquet"
      entity_type: PersonSurvey
      id_col: PERSON_ID
      query: >-
        SELECT *,
        SERIALNO || '_' || CAST(SPORDER AS VARCHAR) AS PERSON_ID,
        CASE WHEN ESR IN (1, 2) THEN 'employed' WHEN ESR = 3 THEN 'unemployed' WHEN ESR IN (4, 5) THEN 'armed_forces' WHEN ESR = 6 THEN 'nilf' ELSE 'not_applicable' END AS employment_status,
        CASE WHEN SCHL < 16 THEN 'less_than_hs' WHEN SCHL IN (16, 17) THEN 'hs_or_ged' WHEN SCHL BETWEEN 18 AND 20 THEN 'some_college' WHEN SCHL = 21 THEN 'bachelors' WHEN SCHL > 21 THEN 'graduate' ELSE 'not_applicable' END AS edu_level,
        CASE WHEN AGEP < 18 THEN 'child' WHEN AGEP < 65 THEN 'working_age' ELSE 'senior' END AS age_cohort,
        CASE WHEN JWTRNS IN (1, 2, 3) THEN 'car' WHEN JWTRNS IN (4, 5, 6, 7, 8) THEN 'transit' WHEN JWTRNS = 11 THEN 'bike' WHEN JWTRNS = 12 THEN 'walk' WHEN JWTRNS = 13 THEN 'wfh' ELSE 'other_or_na' END AS commute_mode,
        CASE WHEN HINS1 = 1 OR HINS2 = 1 OR HINS3 = 1 OR HINS4 = 1 OR HINS5 = 1 OR HINS6 = 1 OR HINS7 = 1 THEN 1 ELSE 0 END AS has_insurance,
        CASE WHEN MIL IN (1, 2, 3) THEN 1 ELSE 0 END AS is_veteran,
        (CASE WHEN DDRS = 1 THEN 1 ELSE 0 END
        + CASE WHEN DEAR = 1 THEN 1 ELSE 0 END
        + CASE WHEN DEYE = 1 THEN 1 ELSE 0 END
        + CASE WHEN DOUT = 1 THEN 1 ELSE 0 END
        + CASE WHEN DPHY = 1 THEN 1 ELSE 0 END
        + CASE WHEN DREM = 1 THEN 1 ELSE 0 END) AS disability_count,
        CASE WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 10 AND 3550 THEN 'mgmt_business_science_arts' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 3601 AND 4655 THEN 'service' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 4700 AND 5940 THEN 'sales_office' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 6005 AND 7640 THEN 'natural_resources_construction' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 7700 AND 9760 THEN 'production_transportation' ELSE 'not_applicable' END AS occ_group,
        CASE WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 10 AND 440 THEN 'management' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 500 AND 960 THEN 'business_financial' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 1005 AND 1240 THEN 'computer_math' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 1305 AND 1560 THEN 'architecture_engineering' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 1600 AND 1980 THEN 'life_physical_social_science' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 2001 AND 2060 THEN 'community_social_service' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 2100 AND 2180 THEN 'legal' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 2205 AND 2555 THEN 'education_library' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 2600 AND 2920 THEN 'arts_design_entertainment' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 3000 AND 3550 THEN 'healthcare_practitioners' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 3601 AND 3655 THEN 'healthcare_support' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 3700 AND 3960 THEN 'protective_service' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 4000 AND 4160 THEN 'food_preparation_serving' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 4200 AND 4255 THEN 'building_grounds' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 4330 AND 4655 THEN 'personal_care_service' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 4700 AND 4965 THEN 'sales' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 5000 AND 5940 THEN 'office_admin_support' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 6005 AND 6130 THEN 'farming_fishing_forestry' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 6200 AND 6950 THEN 'construction_extraction' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 7000 AND 7640 THEN 'installation_maintenance_repair' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 7700 AND 8990 THEN 'production' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 9005 AND 9430 THEN 'transportation' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 9510 AND 9760 THEN 'material_moving' WHEN TRY_CAST(LEFT(SOCP, 4) AS INTEGER) BETWEEN 9800 AND 9830 THEN 'military' ELSE 'not_applicable' END AS occ_subgroup,
        CASE WHEN TRY_CAST(INDP AS INTEGER) BETWEEN 170 AND 490 THEN 'agriculture_mining' WHEN TRY_CAST(INDP AS INTEGER) = 770 THEN 'construction' WHEN TRY_CAST(INDP AS INTEGER) BETWEEN 1070 AND 3990 THEN 'manufacturing' WHEN TRY_CAST(INDP AS INTEGER) BETWEEN 4070 AND 4590 THEN 'wholesale_trade' WHEN TRY_CAST(INDP AS INTEGER) BETWEEN 4670 AND 5791 THEN 'retail_trade' WHEN (TRY_CAST(INDP AS INTEGER) BETWEEN 570 AND 690 OR TRY_CAST(INDP AS INTEGER) BETWEEN 6070 AND 6390) THEN 'transportation_utilities' WHEN TRY_CAST(INDP AS INTEGER) BETWEEN 6471 AND 6781 THEN 'information' WHEN TRY_CAST(INDP AS INTEGER) BETWEEN 6871 AND 7190 THEN 'finance_real_estate' WHEN TRY_CAST(INDP AS INTEGER) BETWEEN 7270 AND 7790 THEN 'professional_management' WHEN TRY_CAST(INDP AS INTEGER) BETWEEN 7860 AND 8470 THEN 'education_healthcare' WHEN TRY_CAST(INDP AS INTEGER) BETWEEN 8561 AND 8690 THEN 'arts_entertainment_food' WHEN TRY_CAST(INDP AS INTEGER) BETWEEN 8770 AND 9290 THEN 'other_services' WHEN TRY_CAST(INDP AS INTEGER) BETWEEN 9370 AND 9590 THEN 'public_administration' WHEN TRY_CAST(INDP AS INTEGER) BETWEEN 9670 AND 9870 THEN 'military_industry' ELSE 'not_applicable' END AS industry_group,
        CASE WHEN LANP IS NULL THEN 'english_only' WHEN TRY_CAST(LANP AS INTEGER) = 1200 THEN 'spanish' WHEN TRY_CAST(LANP AS INTEGER) BETWEEN 1000 AND 1287 THEN 'european' WHEN TRY_CAST(LANP AS INTEGER) BETWEEN 1288 AND 1899 THEN 'south_central_asian' WHEN TRY_CAST(LANP AS INTEGER) BETWEEN 1900 AND 3600 THEN 'east_southeast_asian_pacific' WHEN TRY_CAST(LANP AS INTEGER) BETWEEN 4500 AND 9998 THEN 'middle_eastern_african' ELSE 'other_unspecified' END AS language_group
        FROM source
