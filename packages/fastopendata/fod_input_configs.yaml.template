      entity_type: HousingSurvey
      id_col: SERIALNO
      query: >-
        SELECT *,
        STATE || PUMA AS PUMA_FIPS,
        CASE TEN WHEN 1 THEN 'owned_free' WHEN 2 THEN 'owned_mortgage' WHEN 3 THEN 'rented' ELSE 'other' END AS tenure_type,
        CASE WHEN GRPIP > 30 OR OCPIP > 30 THEN 1 ELSE 0 END AS cost_burdened,
        CASE WHEN BROADBND = 1 OR HISPEED = 1 THEN 'broadband' WHEN ACCESSINET = 1 THEN 'internet_no_broadband' WHEN ACCESSINET = 2 THEN 'no_internet' ELSE 'unknown' END AS internet_tier,
        CASE WHEN NP > RMSP THEN 1 ELSE 0 END AS overcrowded
        FROM source
